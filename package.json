{
  "name": "img-weddings-preedit",
  "version": "1.0.0",
  "description": "Wedding footage pre-editing suite — cut, select, balance, export",
  "main": "dist-electron/main.js",
  "author": "IMG Creative Co.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3",
    "wavesurfer.js": "^7.8.11",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "framer-motion": "^11.15.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.imgcreative.weddings-preedit",
    "productName": "IMG Weddings Preedit",
    "mac": {
      "category": "public.app-category.video",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"],
      "minimumSystemVersion": "13.0",
      "darkModeSupport": true,
      "extendInfo": {
        "NSCameraUsageDescription": "Camera access for live preview",
        "NSMicrophoneUsageDescription": "Microphone access for audio monitoring"
      }
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
